<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Platform Stats</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-slate-900 text-white p-10">

        <!-- Header -->
        <div class="w-full flex justify-between items-center mb-10">
            <h1 class="text-3xl font-bold">Platform Stats</h1>
            <a href="/profile" class="bg-slate-700 rounded-md text-sm p-3">
                ← Back to Profile
            </a>
        </div>

        <!-- Total counts -->
        <div class="flex gap-6 mb-10">

            <div class="bg-slate-800 rounded-lg p-6 w-48 text-center">
                <h2 class="text-4xl font-bold text-pink-500">
                    <%= totalUsers %>
                </h2>
                <p class="text-zinc-400 text-sm mt-2">Total Users</p>
            </div>

            <div class="bg-slate-800 rounded-lg p-6 w-48 text-center">
                <h2 class="text-4xl font-bold text-blue-400">
                    <%= totalPosts %>
                </h2>
                <p class="text-zinc-400 text-sm mt-2">Total Posts</p>
            </div>

        </div>

        <!-- User stats table -->
        <div class="bg-slate-800 rounded-lg p-6 w-1/2">

            <h3 class="text-zinc-400 text-sm mb-4">
                Most Active Users
            </h3>

            <!-- Table header -->
            <div class="flex justify-between text-zinc-500 text-xs uppercase mb-3 px-2">
                <span>User</span>
                <span>Posts</span>
            </div>

            <!-- User rows -->
            <% if (userStats.length === 0) { %>
                <p class="text-zinc-500 text-sm text-center py-4">
                    No posts yet
                </p>
            <% } else { %>
                <% userStats.forEach((stat, index) => { %>
                    <div class="flex justify-between items-center
                                bg-slate-700 rounded-md px-4 py-3 mb-2">

                        <div class="flex items-center gap-3">
                            <!-- Rank number -->
                            <span class="text-zinc-500 text-sm w-5">
                                <%= index + 1 %>
                            </span>
                            <!-- Name and username -->
                            <div>
                                <p class="text-sm font-medium">
                                    <%= stat.name %>
                                </p>
                                <p class="text-zinc-400 text-xs">
                                    @<%= stat.username %>
                                </p>
                            </div>
                        </div>

                        <!-- Post count -->
                        <span class="text-pink-400 font-bold">
                            <%= stat.postCount %>
                        </span>

                    </div>
                <% }) %>
            <% } %>

        </div>

    </div>
</body>
</html>