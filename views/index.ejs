<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>
<body>
    <div class="w-full h-screen bg-slate-900 text-white">
        <h1 class="mb-5 text-3xl">Register</h1>
        <form action="/register" method="post"  >
            <div class="flex flex-col gap-7 text-center max-w-sm">
                <input class="outline-none border-1 py-2 px-3 rounded-sm" placeholder="username" name="username" type="text">
                <input class="outline-none border-1 py-2 px-3 rounded-sm" placeholder="name" name="name" type="text">
                <input class="outline-none border-1 py-2 px-3 rounded-sm" placeholder="age" name="age" type="number">
                <input class="outline-none border-1 py-2 px-3 rounded-sm" placeholder="email" name="email" type="email">
                <input class="outline-none border-1 py-2 px-3 rounded-sm" placeholder="password" name="password" type="password">
                <button class="py-2 px-4 rounded-md bg-pink-700 cursor-pointer text-sm">Create</button>
            </div>
        </form>
    </div>
</body>
</html>