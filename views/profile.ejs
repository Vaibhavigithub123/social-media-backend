<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>
<body>
    <div class="w-full h-full bg-slate-900 text-white p-10">

        <div class="w-full flex justify-end">
            <a href="/logout" class="bg-red-500 rounded-md text-sm p-3 inline-block">Logout</a>
            <a href="/stats" class="bg-slate-700 rounded-md text-sm p-3 inline-block">View Stats</a>
        </div>
        <h1 class="mb-5 text-3xl">Profile</h1>
            <h2 >Hello, <span class="font-thin"><%=user.name%></span> </h2>
            <h3 class="text-zinc-500 text-sm mb-5">You can create your post</h3>
            <form action="/post" method="post">
                <textarea name="content" placeholder="Whats on your mind" class="resize-none p-2 rounded-md bg-transparent outline-none border-1 w-1/2 block mb-2"></textarea>
                <input type="submit" value="create new post" class="block py-2 px-4 rounded-md bg-pink-700 cursor-pointer text-sm">
            </form>

            <div class="posts mt-20">
                <h3 class="text-zinc-500 text-sm mb-5">Your Posts</h3>
                <div class="postcontainer mt-4">

                    <% posts.map((post)=>{%>
                        <div class="p-2 rounded-md bg-slate-700 outline-none border-1 w-1/2 block mb-2 border-zinc-800 ">
                        <h3 class="text-blue-300 font-thin mb-2">@<%=user.username%></h3>
                        <p class="text-sm tracking-tight"><%=post.content%></p>
                         <small ><%=post.likes.length%></small> <!--check how many likes the post has -->
                        <div class="flex mt-3 gap-4">
                            <a class="text-blue-500 text-sm" href="/post/<%=post._id%>/like"> 
                                <!-- check if user has already liked the post if not then show like and if already liked then show unlike -->
                                <!-- ✅ Convert both to string for reliable comparison -->
                                <%= post.likes.map(id => id.toString()).indexOf(user._id.toString()) === -1 ? "Like" : "Unlike" %>
                            </a>
                            <a class="text-zinc-500 text-sm" href="/post/<%=post._id%>/edit">Edit</a>
                        </div>
                    </div>
                    
                    <% })%>

                    <!-- Pagination controls — add this below your posts loop -->

                </div>

                <!-- Pagination controls -->
<div class="pagination flex gap-3 mt-6 items-center ">

  <!-- Previous button -->
  <% if (hasPrevPage) { %>
    <a 
      href="/profile?page=<%= currentPage - 1 %>"
      class="px-3 py-1 bg-slate-700 rounded-md text-sm hover:bg-slate-600"
    >← Previous</a>
  <% } %>

  <!-- Page numbers -->
  <% for(let i = 1; i <= totalPages; i++) { %>
    <a
      href="/profile?page=<%= i %>"
      class="px-3 py-1 rounded-md text-sm <%= i === currentPage ? 'bg-pink-700 font-bold' : 'bg-slate-700 hover:bg-slate-600' %>"
    >
      <%= i %>
    </a>
  <% } %>

  <!-- Next button -->
  <% if (hasNextPage) { %>
    <a 
      href="/profile?page=<%= currentPage + 1 %>"
      class="px-3 py-1 bg-slate-700 rounded-md text-sm hover:bg-slate-600"
    >Next →</a>
  <% } %>

</div>  
                
            </div>
        
    </div>
</body>
</html>